{
  "version": 2,
  "rewrites": [
    { "source": "/api/payfast-create", "destination": "/api/payfast-create.js" },
    { "source": "/api/payfast-itn",    "destination": "/api/payfast-itn.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
